# ============================================================
# FlowNote – Environment Variables Example
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or .env.*.local
# ============================================================

# ── Frontend (Vite) ─────────────────────────────────────────
# Set to 'false' to use the real Azure Functions backend.
# Default (true) uses localStorage mock for local development.
VITE_USE_MOCK_API=true

# SHA-256 hash of the demo password used in password-auth mode.
# Required when VITE_USE_MOCK_API=true or when MSAL is not configured.
# Generate on Linux/Mac:  echo -n 'YOUR_PASSWORD' | sha256sum
# Generate on PowerShell: [System.BitConverter]::ToString([System.Security.Cryptography.SHA256]::Create().ComputeHash([System.Text.Encoding]::UTF8.GetBytes('YOUR_PASSWORD'))).Replace('-','').ToLower()
# Expected format: 64-character lowercase hex string (e.g. a3f4b2c1...)
# In CI (GitHub Actions): set the LOGIN_PASSWORD secret instead – the hash is
# computed automatically at build time. VITE_PASSWORD_HASH is only needed for
# local development.
VITE_PASSWORD_HASH=

# Microsoft Entra ID (Azure AD) アプリ登録のクライアント ID
# ① Azure Portal > Microsoft Entra ID > アプリ登録 > 新規登録 で取得
# ② リダイレクト URI に https://<あなたの SWA ドメイン> を登録（種別: SPA）
# ③ リダイレクト URI は window.location.origin のみ（末尾 / やパスなし）
# 設定するとパスワード認証の代わりに Microsoft Entra ID SSO ポップアップ認証が有効になる
VITE_ENTRA_CLIENT_ID=

# テナント ID（限定したい場合）。未設定の場合は common（マルチテナント）を使用
# VITE_MSAL_TENANT_ID=

# レガシー値 (古い VITE_MSAL_CLIENT_ID があればそのまま使用可)
# VITE_MSAL_CLIENT_ID=

# システム管理者のメールアドレス（カンマ区切り）。
# ユーザー管理画面（ユーザー分析）へのアクセスを許可するユーザーを指定する。
# 未設定の場合、管理者ボタンは表示されない。
# VITE_USE_MOCK_API=true の場合、設定するとモックユーザーも管理者として扱われる（開発・デモ用）。
# 例: VITE_ADMIN_EMAILS=admin@example.com,admin2@example.com
VITE_ADMIN_EMAILS=

# 管理者アクセスを許可するメールドメイン。
# 設定すると、指定ドメインのメールアドレスを持つすべてのユーザーが管理者アクセス可能。
# VITE_ADMIN_EMAILS と併用可。いずれかに一致すれば管理者と判定。
# GitHub Secrets では ADMIN_DOMAIN を設定すれば VITE_ADMIN_DOMAIN にも自動適用される
# 例: VITE_ADMIN_DOMAIN=microsoft.com
VITE_ADMIN_DOMAIN=

# Set to 'false' to use the real AI agent endpoint.
VITE_USE_MOCK_AGENT=true

# Base URL of the Azure Functions app (without trailing slash).
# Used when VITE_USE_MOCK_API=false or VITE_USE_MOCK_AGENT=false.
# Example: https://YOUR-FUNCTION-APP.azurewebsites.net
VITE_API_BASE_URL=http://localhost:7071
VITE_AGENT_API_BASE_URL=http://localhost:7071

# Set to 'true' only when Azure SignalR Service is provisioned.
# Leaving unset (or 'false') disables real-time sync without errors.
VITE_SIGNALR_ENABLED=false

# ── Backend (Azure Functions local.settings.json) ────────────
# These are set in backend/local.settings.json (not committed).
# In production, they are set via Bicep / Azure Portal.

# Azure Storage connection string for note persistence
# STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Blob container name (default: notes)
# NOTES_CONTAINER=notes

# Entra ID クライアント ID（バックエンド idToken/accessToken 検証用）
# POST /api/auth/entra, GET /api/auth/me, GET /api/mgmt/analytics/users で使用
# GitHub Secrets では ENTRA_CLIENT_ID を設定すれば VITE_ENTRA_CLIENT_ID にも自動適用される
# ENTRA_CLIENT_ID=

# システム管理者のメールアドレス（カンマ区切り）。
# GET /api/mgmt/analytics/users へのアクセスを許可するユーザーを指定する。
# 未設定の場合、認証済みユーザー全員がアクセス可能（ENTRA_CLIENT_ID が設定されている場合のみ検証）。
# GitHub Secrets では ADMIN_EMAILS を設定すれば VITE_ADMIN_EMAILS にも自動適用される
# 例: ADMIN_EMAILS=admin@example.com,admin2@example.com
# ADMIN_EMAILS=

# 管理者アクセスを許可するメールドメイン（バックエンド用）。
# 設定すると、指定ドメインのメールアドレスを持つすべての認証済みユーザーが管理者 API にアクセス可能。
# GitHub Secrets では ADMIN_DOMAIN を設定すれば VITE_ADMIN_DOMAIN にも自動適用される
# 例: ADMIN_DOMAIN=microsoft.com
# ADMIN_DOMAIN=

# OpenAI API key for the AI agent
# OPENAI_API_KEY=sk-...

# Azure OpenAI (recommended over OpenAI key; uses managed identity – no API key required)
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT_NAME=YOUR-DEPLOYMENT-NAME
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── Application Insights ────────────────────────────────────
# Connection string from Azure Portal (Application Insights > Overview).
# Leave empty to disable telemetry in local development.
VITE_APPINSIGHTS_CONNECTION_STRING=

# Log Analytics workspace ID（Application Insights の基盤となるワークスペースの GUID）。
# Azure Portal > Application Insights > プロパティ > ワークスペース > 概要 > ワークスペース ID で確認。
# GET /api/mgmt/analytics/users エンドポイントがユーザー活動集計に使用する。
# Bicep でデプロイ時は自動設定される。
# APPINSIGHTS_WORKSPACE_ID=
